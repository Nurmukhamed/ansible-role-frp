bindPort = {{ frp['server']['port'] }}
log.to = "{{ logdir }}/{{ frp['server']['logfile'] }}"
transport.tls.force = {{ frp['server']['tls']['enabled'] }}
transport.tls.certFile = "{{ tlsdir }}/{{ frp['server']['tls']['certificate']}}"
transport.tls.keyFile = "{{ tlsdir }}/{{ frp['server']['tls']['privkey'] }}"
transport.tls.trustedCaFile = "{{ tlsdir }}/{{ frp['server']['tls']['cacrt'] }}"
